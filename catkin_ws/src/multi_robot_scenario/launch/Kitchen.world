    <!-- Cửa động có thể giữ lại như cửa chính hoặc cửa bếp (tùy chọn) -->
    <!-- Di chuyển sliding door ra lối vào chính (phía Nam) -->
    <model name='sliding_door_main'>
      <static>false</static>
      <pose>0 -10 0.5 0 0 0</pose>
      <link name='gate_panel'>
        <!-- ... cấu trúc cửa trượt ... -->
      </link>
      <joint name='sliding_joint' type='prismatic'>
        <parent>world</parent>
        <child>gate_panel</child>
        <axis>
          <xyz>1 0 0</xyz>
          <limit>
            <lower>-1.5</lower>
            <upper>1.5</upper>
          </limit>
        </axis>
      </joint>
      <plugin name='sliding_door_plugin' filename='librotating_wall_plugin.so'>
        <joint_name>sliding_joint</joint_name>
        <amplitude>1.3</amplitude>
        <speed>0.5</speed>
      </plugin>
    </model>

  </world>
</sdf>
