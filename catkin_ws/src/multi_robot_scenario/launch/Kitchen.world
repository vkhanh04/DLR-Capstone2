    <!-- ================= CÁC MÔ HÌNH KHÁC (giữ lại hoặc di chuyển) ================= -->
    <!-- Fire hydrant giữ làm vật trang trí góc -->
    <model name='fire_hydrant'>
      <static>1</static>
      <pose>-9 -9 0 0 0 0</pose>
      <link name='link'>
        <visual name='visual'>
          <geometry>
            <mesh>
              <uri>model://fire_hydrant/meshes/fire_hydrant.dae</uri>
              <scale>1 1 1</scale>
            </mesh>
          </geometry>
        </visual>
        <collision name='collision'>
          <geometry>
            <mesh>
              <uri>model://fire_hydrant/meshes/fire_hydrant.dae</uri>
              <scale>1 1 1</scale>
            </mesh>
          </geometry>
        </collision>
      </link>
    </model>

    <!-- Bookshelf dùng làm kệ trang trí trong bếp -->
    <model name='bookshelf'>
      <static>1</static>
      <pose>-7 -8 0 0 0 0</pose>
      <!-- giữ nguyên cấu trúc bookshelf cũ -->
      <link name='link'>
        <!-- ... giữ nguyên các collision và visual ... -->
      </link>
    </model>

    <!-- ================= CARDBOARD BOXES TRONG PHÒNG BẾP ================= -->
    <!-- Hộp 1 -->
    <model name='cardboard_box_0'>
      <static>1</static>
      <pose>-8.5 -8.0 0.15 0 0 0</pose>
      <link name='link'>
        <inertial>
          <mass>2</mass>
          <inertia>
            <ixx>0.0416</ixx>
            <ixy>0</ixy>
            <ixz>0</ixz>
            <iyy>0.0566</iyy>
            <iyz>0</iyz>
            <izz>0.0683</izz>
          </inertia>
        </inertial>
        <collision name='collision'>
          <geometry>
            <box>
              <size>0.5 0.4 0.3</size>
            </box>
          </geometry>
          <surface>
            <friction>
              <ode>
                <mu>1</mu>
                <mu2>1</mu2>
              </ode>
            </friction>
          </surface>
        </collision>
        <visual name='visual'>
          <pose>0 0 -0.15 0 0 0</pose>
          <geometry>
            <mesh>
              <uri>model://cardboard_box/meshes/cardboard_box.dae</uri>
              <scale>1 1 1</scale>
            </mesh>
          </geometry>
        </visual>
        <self_collide>0</self_collide>
        <kinematic>0</kinematic>
        <gravity>1</gravity>
      </link>
    </model>

